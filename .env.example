APP_NAME = "Linkeding RPA"
LOG_LEVEL = "DEBUG"
HEADLESS="False"

# LLM provider: "langchain" (default) or "claude"
LLM_PROVIDER=langchain

# Claude settings (usado quando LLM_PROVIDER=claude)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# LangChain/Ollama settings (usado quando LLM_PROVIDER=langchain)
LANGCHAIN_MODEL=llama3.2
LANGCHAIN_BASE_URL=http://localhost:11434

# Provider separado para avaliação de vagas (opcional, usa LLM_PROVIDER se não definido)
LLM_PROVIDER_EVAL=claude
LANGCHAIN_MODEL_EVAL=llama3.1:8b